# Sports arb standalone env example.
# Fill secrets in config.env or /etc/sports-arb.env; do not commit real values.

RPC_URL=https://polygon-bor-rpc.publicnode.com
# pool. Used by scripts/lib/polygon-rpc.ts (hourly executor + arb daemon).
POLYGON_RPC_URLS=https://polygon.drpc.org,https://polygon.publicnode.com,https://1rpc.io/matic
# Optional network/proxy controls for live Polymarket access
SOCKS_PROXY=
ALL_PROXY=
# Production runtime state. Dublin/Japan wrappers should set state under /var/lib/sports-arb.
SPORTS_ARB_STATE_DIR=/var/lib/sports-arb
SPORTS_ARB_DATA_DIR=/var/lib/sports-arb/data
SPORTS_ARB_RUNTIME_DIR=/var/lib/sports-arb/runtime
SPORTS_ARB_REPORTS_DIR=/var/lib/sports-arb/data/reports
SPORTS_ARB_BACKUP_DIR=/var/lib/sports-arb/backups
SPORTS_ARB_PNL_LIFETIME_START=2026-06-23T21:50:00.000Z
SPORTS_ARB_PACKAGE_USD=20
SPORTS_ARB_MAX_PACKAGE_USD=20
SPORTS_ARB_MAX_DAILY_USD=200
SPORTS_ARB_MAX_OPEN_PACKAGES=50
SPORTS_ARB_MAX_EVENT_USD=100
SPORTS_ARB_MAX_SPORT_USD=1000
SPORTS_ARB_ORPHAN_DUST_SHARES=1
SPORTS_ARB_LIVE=0
SPORTS_ARB_LLM_ENABLED=0
DEEPSEEK_API_KEY=
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
# Nightly llm:learn overrides DEEPSEEK_MODEL with this (non-reasoning chat).
SPORTS_ARB_LLM_LEARN_MODEL=deepseek-chat
SPORTS_ARB_TELEGRAM_BOT_TOKEN=
SPORTS_ARB_TELEGRAM_CHAT_ID=
# Live monotonic-arb scanner (report/shadow only; no order execution)
MONOTONIC_ARB_LIVE_EVENT_SLUGS=
MONOTONIC_ARB_LIVE_MIN_EDGE=0.001
MONOTONIC_ARB_LIVE_MIN_LIQUIDITY=10000
MONOTONIC_ARB_LIVE_MAX_SPREAD=0.01
MONOTONIC_ARB_LIVE_MIN_SIZE=10
# Real Polymarket monotonic-arb executor.
ENABLE_MONOTONIC_ARB_REAL_PM=0
DISABLE_REAL_PM_TRADING=1
MONOTONIC_ARB_REAL_PM_DRY_RUN=1
MONOTONIC_ARB_REAL_PM_BUILD_ONLY=0
MONOTONIC_ARB_REAL_PM_SOURCE=scan
MONOTONIC_ARB_REAL_PM_PACKAGE_ID=
MONOTONIC_ARB_REAL_PM_MAX_PACKAGE_USD=20
# Keep live entries at the configured package size; when cash is below this,
# the daemon keeps scanning but skips new trades until capital recycles.
MONOTONIC_ARB_REAL_PM_MAX_PACKAGE_USD_CEILING=20
MONOTONIC_ARB_REAL_PM_MAX_DAILY_USD=200
MONOTONIC_ARB_REAL_PM_MAX_PER_RUN=1
MONOTONIC_ARB_REAL_PM_MAX_OPEN_PACKAGES=50
MONOTONIC_ARB_REAL_PM_MIN_EDGE=0.001
MONOTONIC_ARB_REAL_PM_MIN_LIQUIDITY=10000
MONOTONIC_ARB_REAL_PM_MAX_SPREAD=0.01
MONOTONIC_ARB_REAL_PM_MIN_AVAILABLE_SHARES=10
MONOTONIC_ARB_REAL_PM_MIN_ORDER_SHARES=1
MONOTONIC_ARB_REAL_PM_MIN_MARKETABLE_BUY_USD=1
MONOTONIC_ARB_REAL_PM_ASSETS=BTC,ETH,GOLD,SOL,SILVER,SPY,NBA
# Always-on websocket arb daemon (scripts/polymarket-arb-daemon.ts, Japan host).
ARB_DAEMON_MAX_PER_MIN=3
ARB_DAEMON_WATCHLIST_REFRESH_MS=300000
ARB_DAEMON_BALANCE_REFRESH_MS=300000
ARB_DAEMON_LEDGER_FLUSH_MS=120000
ARB_DAEMON_FILL_WAIT_MS=3000
ARB_DAEMON_PING_MS=10000
ARB_DAEMON_DISCOVER_MLB_GAMES=1
ARB_DAEMON_MAX_NAKED_SHARES_BEFORE_PAUSE=25
ARB_DAEMON_BALANCE_HEADROOM_USD=0.5
ARB_DAEMON_NEAR_MISS_LOG_MS=60000
ARB_DAEMON_NEAR_MISS_TOP_N=5
ARB_DAEMON_CAPTURE_AUDIT_MIN_COST=0.95
ARB_DAEMON_CAPTURE_AUDIT_MAX_COST=2.00
ARB_DAEMON_CAPTURE_AUDIT_MIN_INTERVAL_MS=5000
# SPORTS_MIN_EDGE=0.01 requires >=1c of locked edge (pair cost <= 0.99) before we
ARB_DAEMON_SPORTS_MIN_EDGE=0.01
ARB_DAEMON_SPORTS_MIN_AVAILABLE_SHARES=5
ARB_DAEMON_SPORTS_MAX_SPREAD=0.04
ARB_DAEMON_SPORTS_MAX_PAIRED_SHARES=0
ARB_DAEMON_SPORTS_DEPTH_RESERVE_MULTIPLIER=2
ARB_DAEMON_SPORTS_PRICE_SLIPPAGE=0
ARB_DAEMON_SPORTS_ENTRY_CUTOFF_MS=0
ARB_DAEMON_SPORTS_ORPHAN_DUST_SHARES=25
ARB_DAEMON_SPORTS_BALANCE_HEADROOM_USD=0.5
ARB_DAEMON_SPORTS_BALANCE_HEADROOM_MULTIPLIER=1.03
# Risk-free because the monotonic-middle floor always pays >= $1. Set to 0 to
ARB_DAEMON_SPORTS_HEDGE_BREAKEVEN_FILL=1
ARB_DAEMON_SPORTS_HEDGE_COMPLETION_MIN_EDGE=0
# Prefer the cheapest live-eligible soccer package when several exist on one event (default on).
# ARB_DAEMON_SOCCER_PREFER_CHEAPEST_EVENT_PACKAGE=0
# Per-family live cost ceilings (backtest-evidence caps; T3 band alone is not enough).
# ARB_DAEMON_SOCCER_MAX_COST_3_5_6_5=1.20
# ARB_DAEMON_SOCCER_MAX_COST_2_5_4_5=1.22
ARB_DAEMON_NON_SPORTS_EXCHANGE_MIN_BUFFER_SHARES=25
ARB_DAEMON_STALE_SUBMITTED_MS=600000
ARB_DAEMON_NBA_LEDGER_ARCHIVE_GRACE_MS=86400000
ARB_DAEMON_GIT_PUSH=0
ARB_DAEMON_PULL_ON_START=0
# ladder into a positive-EV monotonic package, and falls back to flattening
ARB_DAEMON_ORPHAN_POLL_MS=1000
ARB_DAEMON_ORPHAN_STOP_CENTS=0.01
ARB_DAEMON_ORPHAN_COMPLETION_MARGIN=0.01
ARB_DAEMON_NON_SPORTS_ORPHAN_COMPLETION_MARGIN=0
ARB_DAEMON_ORPHAN_EXPIRY_BUFFER_MS=600000
ARB_DAEMON_ORPHAN_LADDER_REFRESH_MS=5000
ARB_DAEMON_ORPHAN_MIN_SHARES=1
ARB_DAEMON_DUST_EXIT_LIMIT_WAIT_MS=5000
ARB_DAEMON_DUST_EXIT_RETRY_MS=60000
ARB_DAEMON_DUST_EXIT_MIN_MARKETABLE_BUY_USD=1
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com
POLYMARKET_RELAYER_TX_TYPE=PROXY
POLYMARKET_PROXY_WALLET_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=1
POLYMARKET_FUNDER_ADDRESS=
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=

# --- Kalshi MLB shadow screener (Phase 1+2: read-only) ---
# Generate API keys at https://kalshi.com (Profile -> Security -> API Keys).
# The private key is a single-use download from Kalshi; save it as a .pem file
# and chmod 600 on the VPS at the path below. Set KALSHI_ENV=demo to test
# against the demo API first.
KALSHI_API_KEY_ID=
KALSHI_API_PRIVATE_KEY_PATH=/etc/kalshi/kalshi.pem
KALSHI_ENV=production
KALSHI_MLB_SERIES_TICKER=KXMLBGAME
KALSHI_SCREENER_REFRESH_MS=30000
KALSHI_SCREENER_MAX_WIDTH=4
KALSHI_SCREENER_MIN_LIQUIDITY=100
